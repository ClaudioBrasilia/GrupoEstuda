# Supabase Configuration
# Substitua pelos valores do seu projeto Supabase em https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Opcional: Se estiver usando Capacitor para Android/iOS, certifique-se de que o domínio do Supabase
# esteja permitido nas configurações de rede (Network/App Transport Security).
